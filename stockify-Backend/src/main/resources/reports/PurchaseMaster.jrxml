    <dataset name="Dataset1" uuid="087b05de-b394-455d-9513-560de04c6b90">
        <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
        <property name="com.jaspersoft.studio.data.defaultdataadapter" value="INV"/>
        <parameter name="purchase_id" class="java.lang.Long"/>
        <query language="SQL"><![CDATA[SELECT
   pu.purchase_id as productid,
    pr.product_name as name,
    pu.total,
    CAST(pu.created_on AS date) as purchase_date
FROM purchase pu
JOIN product pr ON pu.product_id = pr.product_id
WHERE pu.purchase_id = $P{purchase_id}
]]></query>
        <field name="productid" class="java.lang.Long">
            <property name="com.jaspersoft.studio.field.name" value="productid"/>
